generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  lyzrAccountId  String        @unique
  email          String        @unique
  name           String
  credits        Float         @default(0)
  createdAt      DateTime      @default(now())
  dataSources    DataSource[]
  actions        Action[]
  chatMessages   ChatMessage[]
  actionEvents   ActionEvent[]
  documents      Document[]
}

model DataSource {
  id          String   @id @default(cuid())
  userId      String
  type        String
  name        String
  status      String   @default("processing")
  recordCount Int      @default(0)
  metadata    String?
  createdAt   DateTime @default(now())

  user      User              @relation(fields: [userId], references: [id])
  records   FinancialRecord[]
  actions   Action[]
  invoices  Invoice[]
  documents Document[]
}

model FinancialRecord {
  id           String @id @default(cuid())
  dataSourceId String
  account      String
  period       String
  actual       Float
  budget       Float
  category     String

  dataSource DataSource @relation(fields: [dataSourceId], references: [id])
}

model Action {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  severity           String
  headline           String
  detail             String
  driver             String
  status             String   @default("pending")
  sourceDataSourceId String
  invoiceId          String?
  draftBody          String?
  createdAt          DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  dataSource   DataSource   @relation(fields: [sourceDataSourceId], references: [id])
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])
  chatMessages ChatMessage[]
  events       ActionEvent[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  timestamp DateTime @default(now())
  actionId  String?

  user   User    @relation(fields: [userId], references: [id])
  action Action? @relation(fields: [actionId], references: [id])
}

model ActionEvent {
  id         String   @id @default(cuid())
  actionId   String
  userId     String
  fromStatus String
  toStatus   String
  createdAt  DateTime @default(now())

  action Action @relation(fields: [actionId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

model Invoice {
  id            String    @id @default(cuid())
  dataSourceId  String
  invoiceNumber String
  customer      String
  customerEmail String?
  amount        Float
  invoiceDate   DateTime
  dueDate       DateTime
  status        String    @default("open")
  lastDunnedAt  DateTime?
  snoozedUntil  DateTime?
  createdAt     DateTime  @default(now())

  dataSource DataSource @relation(fields: [dataSourceId], references: [id])
  actions    Action[]

  @@unique([dataSourceId, invoiceNumber])
}

model Document {
  id           String   @id @default(cuid())
  userId       String
  type         String   // "variance_report" | "ar_summary"
  title        String
  body         String
  dataSourceId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  dataSource DataSource? @relation(fields: [dataSourceId], references: [id])
}