# Example environment variables (DO NOT commit real secrets)
# Create a local `.env` (gitignored) and populate with real values.

# Postgres connection string. On Netlify, use Neon's pooled URL
# (ends with `-pooler.<region>.aws.neon.tech`) to avoid Lambda cold-start connection exhaustion.
DATABASE_URL="postgres://USERNAME:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Lyzr AI Studio / OpenAI-compatible API key (placeholder)
LYZR_API_KEY="sk-your-lyzr-api-key"
OPENAI_API_KEY="sk-your-openai-key"

# Google Gemini (OPTIONAL)
GEMINI_API_KEY="your-gemini-key"
