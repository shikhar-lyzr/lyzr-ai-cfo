# Example environment variables (DO NOT commit real secrets)
# Create a local `.env` (gitignored) and populate with real values.

# Database (placeholder — do NOT commit real credentials)
# Example for Postgres: postgres://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgres://USERNAME:PASSWORD@HOST:PORT/DATABASE"

# Lyzr AI Studio / OpenAI-compatible API key (placeholder)
LYZR_API_KEY="sk-your-lyzr-api-key"
OPENAI_API_KEY="sk-your-openai-key"

# Google Gemini (OPTIONAL)
GEMINI_API_KEY="your-gemini-key"
